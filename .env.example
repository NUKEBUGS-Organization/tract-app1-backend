# Copy to .env for local dev. On Vercel, set the same keys under Project → Settings → Environment Variables (Production).

PORT=3000
ALLOWED_ORIGINS=http://localhost:3000

MONGODB_URI=
MONGODB_DB_NAME=

JWT_SECRET=
JWT_REFRESH_SECRET=

MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM_NAME=TractApp

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ATTOM Data API — parcel data lookup for prefilling the create-listing form
ATTOM_API_KEY=
# Optional overrides — defaults shown
# ATTOM_API_URL=https://api.gateway.attomdata.com
# ATTOM_PROPERTY_ENDPOINT=/propertyapi/v1.0.0/property/expandedprofile

# Google Places API — address typeahead (Places API, autocomplete + details)
GOOGLE_PLACES_API_KEY=

# Optional: comma-separated DNS servers for Node (fixes some Windows SRV lookup issues)
# NODE_DNS_SERVERS=192.168.1.1
