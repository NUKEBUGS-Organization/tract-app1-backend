# Copy to .env for local dev. On Vercel/Render, set the same keys under Environment Variables.

PORT=3000
# Comma-separated SPA origins (required). Include both Tract frontends for cross-app cookie SSO.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://seller.tractcorp.com,https://buyer.tractcorp.com

MONGODB_URI=
MONGODB_DB_NAME=

# Access-token secret (App 1 only). May differ from App 2's JWT_ACCESS_SECRET.
JWT_SECRET=
# MUST match App 2 JWT_REFRESH_SECRET exactly — shared httpOnly refresh cookie SSO on .tractcorp.com
JWT_REFRESH_SECRET=

# Public HTTPS origin of this API (no trailing slash). Used as Jumio KYC callbackUrl.
# Required in production. Example: https://seller-backend.tractcorp.com
API_PUBLIC_URL=

MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM_NAME=TractApp

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ATTOM Data API — parcel data lookup for prefilling the create-listing form
ATTOM_API_KEY=
# Optional overrides — defaults shown
# ATTOM_API_URL=https://api.gateway.attomdata.com
# ATTOM_PROPERTY_ENDPOINT=/propertyapi/v1.0.0/property/expandedprofile

# Google Places API — address typeahead (Places API, autocomplete + details)
GOOGLE_PLACES_API_KEY=

# Optional: comma-separated DNS servers for Node (fixes some Windows SRV lookup issues)
# NODE_DNS_SERVERS=192.168.1.1
