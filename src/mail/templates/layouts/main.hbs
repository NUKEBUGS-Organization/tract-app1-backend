<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>TRACT</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <!--[if mso]>
  <noscript>
    <xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml>
  </noscript>
  <![endif]-->
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background-color: #f0ebe0;
      font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
      font-size: 15px;
      line-height: 1.6;
      color: #1a1a1a;
      -webkit-text-size-adjust: 100%;
      -ms-text-size-adjust: 100%;
    }
    .email-wrapper {
      width: 100%;
      background-color: #f0ebe0;
      padding: 40px 16px;
    }
    .email-card {
      max-width: 580px;
      margin: 0 auto;
      background-color: #f7f2e8;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 2px 16px rgba(23, 77, 52, 0.10);
    }
    .email-header {
      background-color: #174d34;
      padding: 32px 40px 28px;
      text-align: center;
    }
    .email-header img {
      height: 70px;
      display: block;
      margin: 0 auto;
    }
    .email-header .logo-fallback {
      color: #f7f2e8;
      font-size: 26px;
      font-weight: 700;
      letter-spacing: 2px;
    }
    .email-body {
      padding: 36px 40px 32px;
    }
    .email-body h1 {
      font-size: 22px;
      font-weight: 700;
      color: #174d34;
      margin-bottom: 12px;
      line-height: 1.3;
    }
    .email-body p {
      color: #333;
      margin-bottom: 16px;
      font-size: 15px;
    }
    .email-body p.muted {
      color: #666;
      font-size: 13px;
    }
    .info-box {
      background-color: #eae5d8;
      border-left: 4px solid #174d34;
      border-radius: 6px;
      padding: 16px 20px;
      margin: 20px 0;
    }
    .info-box .info-row {
      display: block;
      overflow: hidden;
      padding: 6px 0;
      font-size: 14px;
      border-bottom: 1px solid #d5cfc2;
    }
    .info-box .info-row:last-child { border-bottom: none; }
    .info-box .info-label {
      color: #555;
      font-weight: 500;
      float: left;
    }
    .info-box .info-value {
      color: #174d34;
      font-weight: 700;
      float: right;
    }
    .btn-wrap { text-align: center; margin: 28px 0 8px; }
    .btn {
      display: inline-block;
      background-color: #174d34;
      color: #f7f2e8 !important;
      text-decoration: none;
      font-weight: 600;
      font-size: 15px;
      padding: 14px 32px;
      border-radius: 8px;
      letter-spacing: 0.3px;
    }
    .btn:hover { background-color: #1e6445; }
    .divider {
      border: none;
      border-top: 1px solid #ddd8cc;
      margin: 24px 0;
    }
    .alert-box {
      background-color: #fff8e6;
      border: 1px solid #e8c84a;
      border-radius: 6px;
      padding: 14px 18px;
      margin: 16px 0;
      font-size: 14px;
      color: #7a5c00;
    }
    .email-footer {
      background-color: #174d34;
      padding: 24px 40px;
      text-align: center;
    }
    .email-footer p {
      color: #a8c4b5;
      font-size: 12px;
      margin-bottom: 4px;
    }
    .email-footer a {
      color: #c8dfd4;
      text-decoration: none;
    }
    .email-footer a:hover { text-decoration: underline; }
    @media only screen and (max-width: 600px) {
      .email-body  { padding: 24px 20px; }
      .email-header { padding: 24px 20px; }
      .email-footer { padding: 20px; }
      .info-box .info-row { flex-direction: column; gap: 2px; }
    }
  </style>
</head>
<body>
  <div class="email-wrapper" style="width: 100%; background-color: #f0ebe0; padding: 40px 16px; font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;">
    <div class="email-card" style="max-width: 580px; margin: 0 auto; background-color: #f7f2e8; border-radius: 12px; overflow: hidden;">

      <!-- Header -->
      <div class="email-header" style="background-color: #174d34; padding: 32px 40px 28px; text-align: center;">
        <img src="{{logoUrl}}" alt="TRACT" onerror="this.style.display='none'" style="height: 70px; display: block; margin: 0 auto;" />
        <div class="logo-fallback" style="display:none; color: #f7f2e8; font-size: 26px; font-weight: 700; letter-spacing: 2px;">TRACT</div>
      </div>

      <!-- Body injected by each template -->
      {{{body}}}

      <!-- Footer -->
      <div class="email-footer" style="background-color: #174d34; padding: 24px 40px; text-align: center; font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;">
        <p style="color: #a8c4b5; font-size: 12px; margin-bottom: 4px;">© {{currentYear}} TRACT &amp; BUYTRACT. All rights reserved.</p>
        <p style="color: #a8c4b5; font-size: 12px; margin-bottom: 4px;">
          <a href="{{appUrl}}/settings/notifications" style="color: #c8dfd4; text-decoration: none;">Manage notifications</a>
          &nbsp;·&nbsp;
          <a href="{{appUrl}}/help" style="color: #c8dfd4; text-decoration: none;">Help Center</a>
        </p>
        <p style="margin-top:8px; font-size:11px; color:#7a9e8e;">
          You received this email because you have an active account on TRACT.<br/>
          This is a transactional notification and cannot be unsubscribed from.
        </p>
      </div>

    </div>
  </div>
</body>